# Network Rail STOMP feed credentials
STOMP_HOST=publicdatafeeds.networkrail.co.uk
STOMP_PORT=61618
STOMP_USER=your_email@example.com
STOMP_PASS=your_password
STOMP_QUEUE=/topic/TRAIN_MVT_ALL_TOC

# Kafka topics & connection
TRAIN_MOVEMENTS_TOPIC=rail_movement_raw
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# STOMP reconnect settings
RECONNECT_DELAY_SECS=5
HEARTBEAT_INTERVAL_MS=15000

# Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379

# Google Cloud / BigQuery
BQ_PROJECT_ID=rail-511
BQ_DATASET=rail_data
BQ_TABLE=rail_schedule_raw
GCS_BUCKET=rail_storage
GCP_SA_KEYFILE=./service-account.json

# dbt
DBT_KEYFILE_PATH=./service-account.json

# Kafka Connect
KAFKA_CONNECT_URL=http://localhost:8083/connectors

# ── Airflow ────────────────────────────────────────────────────────────────────
# Fernet key for encrypting connection passwords in Airflow metadata DB.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# Admin credentials created by airflow-init on first run.
# Change these before exposing the UI publicly.
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=changeme
