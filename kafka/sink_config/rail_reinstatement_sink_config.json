{
  "name": "rail-reinstatement-sink",
  "config": {
    "connector.class": "com.wepay.kafka.connect.bigquery.BigQuerySinkConnector",
    "tasks.max": "1",
    "topics": "rail_reinstatement_clean",
    "project": "rail-511",
    "defaultDataset": "rail_data",
    "keyfile": "/etc/kafka-connect/service-account.json",
    "autoCreateTables": "false",
