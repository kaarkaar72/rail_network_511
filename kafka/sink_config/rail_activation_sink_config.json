{
  "name": "rail-activation-sink",
  "config": {
    "connector.class": "com.wepay.kafka.connect.bigquery.BigQuerySinkConnector",
    "tasks.max": "1",
    "topics": "rail_activation_clean",
    "project": "rail-511",
    "defaultDataset": "rail_data",
    "keyfile": "/etc/kafka-connect/service-account.json",
    "autoCreateTables": "false",
    "sanitizeTopics": "true",
    "bigQueryPartitionDecorator": "false",
    "tableNameFormat": "activation"
  }
}
